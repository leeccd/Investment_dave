          <div style="display:flex;flex-direction:column;gap:14px;">
            <div style="padding:14px 16px;border:1px solid var(--border);border-radius:3px;">
              <div style="font-family:var(--mono);font-size:11px;color:var(--gold);letter-spacing:0.08em;text-transform:uppercase;margin-bottom:6px;">Option 1 — Netlify Drop (30 seconds)</div>
              <div style="font-size:13px;color:var(--ink);line-height:1.6;">Go to <span style="font-family:var(--mono);font-size:12px;color:var(--teal);">netlify.com/drop</span> and drag this HTML file onto the page. You get a live URL instantly. No account needed for a temporary link.</div>
            </div>
            <div style="padding:14px 16px;border:1px solid var(--border);border-radius:3px;">
              <div style="font-family:var(--mono);font-size:11px;color:var(--teal);letter-spacing:0.08em;text-transform:uppercase;margin-bottom:6px;">Option 2 — GitHub Pages (permanent)</div>
              <div style="font-size:13px;color:var(--ink);line-height:1.6;">Create a free GitHub account → new repository → upload this file as <span style="font-family:var(--mono);font-size:12px;">index.html</span> → Settings → Pages → enable. Your URL: <span style="font-family:var(--mono);font-size:12px;color:var(--teal);">yourusername.github.io/repo</span></div>
            </div>
            <div style="padding:14px 16px;border:1px solid var(--border);border-radius:3px;">
              <div style="font-family:var(--mono);font-size:11px;color:var(--muted);letter-spacing:0.08em;text-transform:uppercase;margin-bottom:6px;">Important — API Key Security</div>
              <div style="font-size:13px;color:var(--muted);line-height:1.6;">Enter your API key via this Settings panel each session — it is stored only in memory and never embedded in the file. Do not hardcode your key into the HTML before sharing or publishing.</div>
            </div>
          </div>
        </div>
      </div>

    </div><!-- /content -->
  </main>
</div>

<script>
  // API KEY MANAGEMENT
  let _apiKey = '';

  function saveApiKey() {
    const val = document.getElementById('api-key-input').value.trim();
    if (!val.startsWith('sk-ant-')) {
      document.getElementById('api-status').textContent = '✗ Key must start with sk-ant-';
      document.getElementById('api-status').style.color = 'var(--red)';
      return;
    }
    _apiKey = val;
    document.getElementById('api-status').textContent = '✓ Saved for this session';
    document.getElementById('api-status').style.color = 'var(--teal)';
    document.getElementById('api-saved-indicator').style.display = 'block';
    document.getElementById('api-key-input').value = '•'.repeat(Math.min(val.length, 32));
  }

  function clearApiKey() {
    _apiKey = '';
    document.getElementById('api-key-input').value = '';
    document.getElementById('api-status').textContent = 'Key cleared';
    document.getElementById('api-status').style.color = 'var(--muted)';
    document.getElementById('api-saved-indicator').style.display = 'none';
  }

  function toggleApiVisibility() {
    const inp = document.getElementById('api-key-input');
    const btn = document.getElementById('api-toggle-btn');
    if (inp.type === 'password') { inp.type = 'text'; btn.textContent = 'Hide'; }
    else { inp.type = 'password'; btn.textContent = 'Show'; }
  }

  function getApiKey() {
    // In Claude.ai preview, no key needed (handled by Claude environment)
    // When self-hosted, use the saved key
    return _apiKey || null;
  }

  // NAV
  function showPanel(id, el) {
    document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
    document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
    document.getElementById('panel-' + id).classList.add('active');
    el.classList.add('active');
    const titles = {
      dashboard: ['Portfolio Overview', 'Monday, 8 June 2026 · ASX & SGX markets'],
      watchlist: ['My Watchlist', 'Stocks on radar · add & track'],
      screener: ['Value Screener', 'Filter ASX & SGX by Graham criteria'],
      valuator: ['Valuation Tools', 'DCF & Graham Number calculator'],
      advisor: ['Ask the Guru', 'AI-powered investment analysis'],
      checklist: ['Pre-Buy Checklist', 'Run through before every purchase'],
      persona: ['My Persona', 'The Hybrid Value Compounder identity'],
      rules: ['Golden Rules', 'The 6 rules that govern every decision'],
      settings: ['Settings', 'API key & hosting configuration']
    };
    document.getElementById('page-title').textContent = titles[id][0];
    document.getElementById('page-subtitle').textContent = titles[id][1];
  }

  // WATCHLIST
  function addToWatchlist() {
    const ticker = document.getElementById('wl-ticker').value.trim();
    const name = document.getElementById('wl-name').value.trim();
    const market = document.getElementById('wl-market').value;
    const sector = document.getElementById('wl-sector').value.trim();
    const price = document.getElementById('wl-price').value.trim();
    if (!ticker) return;
    const row = document.createElement('tr');
    const today = new Date().toLocaleDateString('en-AU', {day:'numeric', month:'short', year:'numeric'});
    const badgeClass = market === 'SGX' ? 'badge-teal' : 'badge-gold';
    row.innerHTML = `<td><span class="ticker">${ticker}</span></td><td>${name||'—'}</td><td><span class="badge ${badgeClass}">${market}</span></td><td>${sector||'—'}</td><td style="font-family:var(--mono);">${price||'—'}</td><td style="font-family:var(--mono);font-size:11px;color:var(--muted);">${today}</td><td><span style="font-family:var(--mono);font-size:11px;color:var(--red);cursor:pointer;" onclick="this.closest('tr').remove()">remove</span></td>`;
    document.getElementById('wl-body').appendChild(row);
    ['wl-ticker','wl-name','wl-sector','wl-price'].forEach(id => document.getElementById(id).value='');
  }

  // SCREENER
  const screenData = [
    {ticker:'CICT.SI', name:'CapitaLand Integrated CT', market:'SGX', pe:14.2, yield:5.8, pb:1.1, moat:'Wide'},
    {ticker:'MLT.SI', name:'Mapletree Logistics', market:'SGX', pe:16.1, yield:5.2, pb:1.3, moat:'Narrow'},
    {ticker:'BHP.AX', name:'BHP Group', market:'ASX', pe:11.8, yield:4.9, pb:2.1, moat:'Wide'},
    {ticker:'NAB.AX', name:'National Australia Bank', market:'ASX', pe:13.4, yield:5.6, pb:1.8, moat:'Wide'},
    {ticker:'WBC.AX', name:'Westpac Banking', market:'ASX', pe:12.9, yield:5.9, pb:1.5, moat:'Narrow'},
    {ticker:'FMG.AX', name:'Fortescue', market:'ASX', pe:8.2, yield:7.4, pb:2.3, moat:'Narrow'},
    {ticker:'CT.SI', name:'CapitaLand Ascendas REIT', market:'SGX', pe:15.3, yield:5.4, pb:1.2, moat:'Wide'},
    {ticker:'CBA.AX', name:'Commonwealth Bank', market:'ASX', pe:22.1, yield:3.4, pb:3.8, moat:'Wide'},
    {ticker:'WES.AX', name:'Wesfarmers', market:'ASX', pe:26.4, yield:2.8, pb:5.2, moat:'Wide'},
    {ticker:'DBS.SI', name:'DBS Group', market:'SGX', pe:10.2, yield:5.2, pb:1.9, moat:'Wide'},
  ];

  function runScreener() {
    const market = document.getElementById('sc-market').value;
    const maxPE = parseFloat(document.getElementById('sc-pe').value) || 99;
    const minYield = parseFloat(document.getElementById('sc-yield').value) || 0;
    const maxPB = parseFloat(document.getElementById('sc-pb').value) || 99;
    const moatReq = document.getElementById('sc-moat').value;

    let results = screenData.filter(s => {
      if (market !== 'Both' && s.market !== market) return false;
      if (s.pe > maxPE) return false;
      if (s.yield < minYield) return false;
      if (s.pb > maxPB) return false;
      if (moatReq === 'Wide only' && s.moat !== 'Wide') return false;
      if (moatReq === 'Narrow+' && s.moat === 'None') return false;
      return true;
    });

    document.getElementById('screen-count').textContent = `— ${results.length} result${results.length!==1?'s':''} found`;
    const body = document.getElementById('screen-body');
    if (results.length === 0) {
      body.innerHTML = '<tr><td colspan="8" style="color:var(--muted);font-size:13px;padding:20px 0;text-align:center;">No stocks match your criteria — try relaxing the filters</td></tr>';
      return;
    }
    body.innerHTML = results.map(s => {
      const badgeClass = s.market==='SGX'?'badge-teal':'badge-gold';
      const moatClass = s.moat==='Wide'?'moat-wide':s.moat==='Narrow'?'moat-narrow':'moat-none';
      const score = Math.round(100 - (s.pe/maxPE)*30 - (maxPB-s.pb)/maxPB*20 + (s.yield/minYield)*20);
      const capped = Math.min(Math.max(score, 50), 95);
      const verdict = s.pe<12&&s.yield>5?'<span class="badge badge-teal">Strong buy</span>':s.pe<16?'<span class="badge badge-gold">Watch</span>':'<span class="badge">Monitor</span>';
      return `<tr>
        <td><span class="ticker">${s.ticker}</span></td>
        <td>${s.name}</td>
        <td><span class="badge ${badgeClass}">${s.market}</span></td>
        <td style="font-family:var(--mono);">${s.pe.toFixed(1)}x</td>
        <td style="font-family:var(--mono);color:var(--teal);">${s.yield.toFixed(1)}%</td>
        <td style="font-family:var(--mono);">${s.pb.toFixed(1)}x</td>
        <td><span class="moat ${moatClass}">${s.moat}</span></td>
        <td>${verdict}</td>
      </tr>`;
    }).join('');
  }

  // DCF
  function calcDCF() {
    const eps = parseFloat(document.getElementById('v-eps').value);
    const g = parseFloat(document.getElementById('v-growth').value)/100;
    const tg = parseFloat(document.getElementById('v-tgr').value)/100;
    const r = parseFloat(document.getElementById('v-wacc').value)/100;
    if (isNaN(eps)||isNaN(g)||isNaN(tg)||isNaN(r)||r<=tg) return;
    let pv=0, cf=eps;
    for(let i=1;i<=5;i++){cf*=(1+g);pv+=cf/Math.pow(1+r,i);}
    const tv=(cf*(1+tg))/(r-tg);
    const pvtv=tv/Math.pow(1+r,5);
    const iv=pv+pvtv;
    const buy=iv*0.70;
    document.getElementById('iv-value').textContent='$'+iv.toFixed(2);
    document.getElementById('iv-buy').textContent='$'+buy.toFixed(2);
    document.getElementById('iv-sell').textContent='$'+iv.toFixed(2);
    document.getElementById('iv-verdict').textContent=`Margin of safety entry at $${buy.toFixed(2)} — a ${(30).toFixed(0)}% discount to intrinsic value.`;
  }

  function calcGraham() {
    const eps = parseFloat(document.getElementById('g-eps').value);
    const bvps = parseFloat(document.getElementById('g-bvps').value);
    if (isNaN(eps)||isNaN(bvps)||eps<0||bvps<0) return;
    const gn = Math.sqrt(22.5*eps*bvps);
    document.getElementById('g-result').textContent='$'+gn.toFixed(2);
  }

  // CHECKLIST
  function toggleCheck(el) {
    el.classList.toggle('done');
    if(el.classList.contains('done')) el.innerHTML='✓';
    else el.innerHTML='';
    const text = el.nextElementSibling;
    text.classList.toggle('done');
    const done = document.querySelectorAll('.check-box.done').length;
    const total = document.querySelectorAll('.check-box').length;
    const el2 = document.getElementById('check-score');
    el2.textContent=`${done} / ${total} completed`;
    if(done===total) el2.style.color='var(--teal)';
    else if(done>=7) el2.style.color='var(--gold)';
    else el2.style.color='var(--muted)';
  }

  function resetChecklist() {
    document.querySelectorAll('.check-box').forEach(b=>{b.classList.remove('done');b.innerHTML='';});
    document.querySelectorAll('.check-text').forEach(t=>t.classList.remove('done'));
    const el=document.getElementById('check-score');
    el.textContent='0 / 10 completed — check each item above';
    el.style.color='var(--muted)';
  }

  // CHAT
  const SYSTEM_PROMPT = `You are the Hybrid Value Compounder — a seasoned investment guru persona for a 54-year-old Australian-Chinese retail investor targeting ASX (Australian Securities Exchange) and SGX (Singapore Exchange) markets.

Your personality blends:
- Warren Buffett & Benjamin Graham: margin of safety, intrinsic value, long-term ownership mindset
- Peter Lynch: invest in what you know, look for stories, accessible language
- Charlie Munger: mental models, inversion thinking, avoiding stupidity
- Ray Dalio: macro awareness, risk balancing, diversification across cycles
- Peter Bernstein: respect for market history, humility about uncertainty

Your investor's profile:
- Age 54, planning 8-12 year investment horizon to retirement
- 25% return last year — above market, disciplined approach
- Focuses on ASX (resources, banks, REITs) and SGX (REITs, financials, Asia plays)
- Australian-Chinese background gives cultural edge in reading Singapore/China-linked companies
- Moderate-to-growth risk profile, 15-20% cash reserve policy
- Prefers concentrated portfolio of 15-20 positions

How you respond:
- Give direct, specific, actionable investment analysis
- Always consider valuation (P/E, P/B, yield, DCF)
- Reference specific ASX and SGX stocks when relevant (BHP, CBA, NAB, WES, FMG, RIO on ASX; CICT, MLT, DBS, OCBC, Mapletree REITs on SGX)
- Mention margin of safety, moats, and capital allocation quality
- Flag macro risks: AUD/SGD FX, RBA/MAS rates, China demand cycles
- Keep responses concise and decisive — 2-4 paragraphs max
- Never recommend speculative or leveraged positions
- Always remind about position sizing and portfolio concentration limits
- Speak with authority but acknowledge uncertainty honestly`;

  async function sendMsg() {
    const input = document.getElementById('chat-in');
    const text = input.value.trim();
    if (!text) return;
    appendMsg('user', text);
    input.value = '';
    const btn = document.getElementById('send-btn');
    btn.disabled = true;

    const typing = appendTyping();

    try {
      const history = buildHistory();
      const key = getApiKey();
      const headers = {'Content-Type':'application/json'};
      if (key) headers['x-api-key'] = key;
      const resp = await fetch('https://api.anthropic.com/v1/messages', {
        method: 'POST',
        headers,
        body: JSON.stringify({
          model: 'claude-sonnet-4-20250514',
          max_tokens: 1000,
          system: SYSTEM_PROMPT,
          messages: history
        })
      });
      if (resp.status === 401) {
        typing.remove();
        appendMsg('guru', '⚠ API key missing or invalid. Please go to Settings (⚙ in the sidebar) and enter your Anthropic API key to use the Guru advisor when self-hosting.');
        btn.disabled = false; return;
      }
      const data = await resp.json();
      const reply = data.content?.find(b=>b.type==='text')?.text || 'I was unable to generate a response. Please try again.';
      typing.remove();
      appendMsg('guru', reply);
    } catch(e) {
      typing.remove();
      appendMsg('guru', 'Network error. Please check your connection and try again.');
    }
    btn.disabled = false;
  }

  function sendChip(el) {
    document.getElementById('chat-in').value = el.textContent;
    sendMsg();
  }

  function buildHistory() {
    const msgs = document.querySelectorAll('.msg:not(.typing-msg)');
    const history = [];
    msgs.forEach(m => {
      if(m.classList.contains('guru') && !m.querySelector('.msg-meta')?.textContent.includes('ready')) {
        history.push({role:'assistant', content: m.querySelector('.msg-bubble').textContent});
      } else if(m.classList.contains('user')) {
        history.push({role:'user', content: m.querySelector('.msg-bubble').textContent});
      }
    });
    return history;
  }

  function appendMsg(role, text) {
    const container = document.getElementById('chat-messages');
    const div = document.createElement('div');
    div.className = `msg ${role}`;
    const initials = role==='guru'?'HV':'AC';
    const time = new Date().toLocaleTimeString('en-AU',{hour:'2-digit',minute:'2-digit'});
    div.innerHTML = `<div class="msg-avatar ${role}">${initials}</div><div><div class="msg-bubble">${text.replace(/\n/g,'<br>')}</div><div class="msg-meta">${role==='guru'?'The Guru':'You'} · ${time}</div></div>`;
    container.appendChild(div);
    container.scrollTop = container.scrollHeight;
    return div;
  }

  function appendTyping() {
    const container = document.getElementById('chat-messages');
    const div = document.createElement('div');
    div.className = 'msg guru typing-msg';
    div.innerHTML = `<div class="msg-avatar guru">HV</div><div><div class="msg-bubble"><div class="loading-dots"><span></span><span></span><span></span></div></div></div>`;
    container.appendChild(div);
    container.scrollTop = container.scrollHeight;
    return div;
  }
</script>
</body>
</html>
