<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>The Hybrid Value Compounder</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;700&family=DM+Mono:wght@300;400;500&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --ink: #1a1a18;
    --paper: #f5f2eb;
    --paper2: #ede9e0;
    --gold: #b8860b;
    --gold-light: #d4a843;
    --gold-pale: #f5ecd0;
    --teal: #1a6b5a;
    --teal-light: #e8f4f0;
    --red: #8b2020;
    --red-light: #fdf0f0;
    --muted: #6b6860;
    --border: rgba(26,26,24,0.12);
    --border-strong: rgba(26,26,24,0.25);
    --serif: 'Playfair Display', Georgia, serif;
    --mono: 'DM Mono', monospace;
    --sans: 'DM Sans', sans-serif;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: var(--paper);
    color: var(--ink);
    font-family: var(--sans);
    min-height: 100vh;
    font-size: 15px;
    line-height: 1.6;
  }

  /* LAYOUT */
  .app { display: grid; grid-template-columns: 260px 1fr; min-height: 100vh; }

  /* SIDEBAR */
  .sidebar {
    background: var(--ink);
    color: var(--paper);
    padding: 0;
    display: flex;
    flex-direction: column;
    position: sticky;
    top: 0;
    height: 100vh;
    overflow-y: auto;
  }

  .sidebar-brand {
    padding: 28px 24px 20px;
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }

  .brand-label {
    font-family: var(--mono);
    font-size: 9px;
    letter-spacing: 0.18em;
    color: var(--gold-light);
    text-transform: uppercase;
    margin-bottom: 6px;
  }

  .brand-title {
    font-family: var(--serif);
    font-size: 18px;
    font-weight: 500;
    line-height: 1.3;
    color: #fff;
  }

  .brand-sub {
    font-size: 11px;
    color: rgba(245,242,235,0.45);
    margin-top: 4px;
    font-family: var(--mono);
  }

  .nav-section {
    padding: 16px 0 8px;
    flex: 1;
  }

  .nav-group-label {
    font-family: var(--mono);
    font-size: 9px;
    letter-spacing: 0.15em;
    color: rgba(245,242,235,0.3);
    text-transform: uppercase;
    padding: 8px 24px 4px;
  }

  .nav-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 9px 24px;
    font-size: 13px;
    color: rgba(245,242,235,0.6);
    cursor: pointer;
    transition: all 0.15s;
    border-left: 2px solid transparent;
    font-family: var(--sans);
    font-weight: 300;
    letter-spacing: 0.01em;
  }

  .nav-item:hover { color: #fff; background: rgba(255,255,255,0.04); }

  .nav-item.active {
    color: #fff;
    border-left-color: var(--gold-light);
    background: rgba(212,168,67,0.08);
  }

  .nav-icon { font-size: 15px; opacity: 0.7; }

  .sidebar-footer {
    padding: 16px 24px;
    border-top: 1px solid rgba(255,255,255,0.08);
  }

  .profile-pill {
    display: flex; align-items: center; gap: 10px;
  }

  .profile-avatar {
    width: 32px; height: 32px; border-radius: 50%;
    background: var(--gold);
    display: flex; align-items: center; justify-content: center;
    font-family: var(--serif); font-size: 13px; color: #fff; font-weight: 500;
    flex-shrink: 0;
  }

  .profile-info p { font-size: 12px; color: rgba(245,242,235,0.9); font-weight: 500; }
  .profile-info span { font-size: 10px; color: rgba(245,242,235,0.35); font-family: var(--mono); }

  /* MAIN */
  .main { background: var(--paper); display: flex; flex-direction: column; min-height: 100vh; }

  .topbar {
    padding: 20px 36px 16px;
    border-bottom: 1px solid var(--border);
    display: flex; align-items: center; justify-content: space-between;
    background: var(--paper);
    position: sticky; top: 0; z-index: 10;
  }

  .page-title {
    font-family: var(--serif);
    font-size: 22px;
    font-weight: 500;
    color: var(--ink);
  }

  .page-subtitle {
    font-size: 12px;
    color: var(--muted);
    font-family: var(--mono);
    margin-top: 2px;
  }

  .topbar-actions { display: flex; gap: 10px; align-items: center; }

  .badge {
    display: inline-flex; align-items: center; gap: 4px;
    padding: 4px 10px; border-radius: 20px;
    font-family: var(--mono); font-size: 11px;
  }

  .badge-gold { background: var(--gold-pale); color: var(--gold); border: 1px solid rgba(184,134,11,0.2); }
  .badge-teal { background: var(--teal-light); color: var(--teal); border: 1px solid rgba(26,107,90,0.2); }
  .badge-red { background: var(--red-light); color: var(--red); border: 1px solid rgba(139,32,32,0.15); }

  /* CONTENT */
  .content { padding: 28px 36px; flex: 1; }

  /* PANELS */
  .panel { display: none; }
  .panel.active { display: block; }

  /* CARDS */
  .card {
    background: #fff;
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 20px 24px;
    margin-bottom: 16px;
  }

  .card-title {
    font-family: var(--serif);
    font-size: 15px;
    font-weight: 500;
    margin-bottom: 12px;
    padding-bottom: 10px;
    border-bottom: 1px solid var(--border);
    display: flex; align-items: center; justify-content: space-between;
  }

  /* METRIC GRID */
  .metrics { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; margin-bottom: 20px; }

  .metric {
    background: #fff;
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 16px 20px;
    position: relative;
    overflow: hidden;
  }

  .metric::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: var(--gold);
  }

  .metric.teal::before { background: var(--teal); }
  .metric.red::before { background: var(--red); }
  .metric.ink::before { background: var(--ink); }

  .metric-label { font-family: var(--mono); font-size: 10px; color: var(--muted); letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 6px; }
  .metric-value { font-family: var(--serif); font-size: 26px; font-weight: 500; line-height: 1; }
  .metric-value.up { color: var(--teal); }
  .metric-value.down { color: var(--red); }
  .metric-delta { font-family: var(--mono); font-size: 11px; color: var(--muted); margin-top: 4px; }

  /* TWO COL */
  .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .three-col { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 16px; }

  /* TABLE */
  table { width: 100%; border-collapse: collapse; font-size: 13px; }
  th { font-family: var(--mono); font-size: 10px; letter-spacing: 0.08em; color: var(--muted); text-transform: uppercase; text-align: left; padding: 8px 0; border-bottom: 1px solid var(--border); font-weight: 400; }
  td { padding: 10px 0; border-bottom: 1px solid rgba(26,26,24,0.06); vertical-align: middle; }
  tr:last-child td { border-bottom: none; }
  .ticker { font-family: var(--mono); font-size: 12px; font-weight: 500; }
  .score-bar { display: flex; align-items: center; gap: 8px; }
  .bar-bg { width: 60px; height: 4px; background: var(--paper2); border-radius: 2px; }
  .bar-fill { height: 4px; border-radius: 2px; background: var(--teal); }
  .moat { display: inline-block; padding: 2px 8px; border-radius: 2px; font-size: 10px; font-family: var(--mono); }
  .moat-wide { background: var(--teal-light); color: var(--teal); }
  .moat-narrow { background: var(--gold-pale); color: var(--gold); }
  .moat-none { background: var(--red-light); color: var(--red); }

  /* DNA BAR CHART */
  .dna-grid { display: flex; flex-direction: column; gap: 10px; }
  .dna-row { display: flex; align-items: center; gap: 12px; }
  .dna-name { font-size: 12px; font-family: var(--mono); color: var(--muted); width: 110px; flex-shrink: 0; }
  .dna-track { flex: 1; height: 6px; background: var(--paper2); border-radius: 1px; }
  .dna-fill { height: 6px; border-radius: 1px; }
  .dna-pct { font-family: var(--mono); font-size: 11px; color: var(--ink); width: 30px; text-align: right; }

  /* CHECKLIST */
  .checklist { display: flex; flex-direction: column; gap: 8px; }
  .check-item { display: flex; align-items: flex-start; gap: 10px; font-size: 13px; padding: 8px 0; border-bottom: 1px solid rgba(26,26,24,0.06); }
  .check-item:last-child { border-bottom: none; }
  .check-box { width: 16px; height: 16px; border: 1.5px solid var(--border-strong); border-radius: 2px; flex-shrink: 0; margin-top: 1px; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: all 0.15s; }
  .check-box.done { background: var(--teal); border-color: var(--teal); color: #fff; font-size: 10px; }
  .check-text { line-height: 1.5; color: var(--ink); }
  .check-text.done { color: var(--muted); text-decoration: line-through; }

  /* CHAT */
  .chat-wrap {
    display: flex; flex-direction: column;
    height: calc(100vh - 130px);
  }

  .chat-messages {
    flex: 1; overflow-y: auto;
    padding: 16px 0;
    display: flex; flex-direction: column; gap: 16px;
  }

  .msg { display: flex; gap: 12px; max-width: 85%; }
  .msg.user { align-self: flex-end; flex-direction: row-reverse; }

  .msg-avatar {
    width: 32px; height: 32px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 12px; flex-shrink: 0; font-family: var(--serif);
    font-weight: 500;
  }

  .msg-avatar.guru { background: var(--ink); color: var(--gold-light); }
  .msg-avatar.user { background: var(--gold); color: #fff; }

  .msg-bubble {
    padding: 12px 16px;
    border-radius: 4px;
    font-size: 14px;
    line-height: 1.65;
    max-width: 480px;
  }

  .msg.guru .msg-bubble { background: #fff; border: 1px solid var(--border); color: var(--ink); }
  .msg.user .msg-bubble { background: var(--ink); color: var(--paper); }

  .msg-meta { font-family: var(--mono); font-size: 10px; color: var(--muted); margin-top: 4px; text-align: right; }

  .chat-input-row {
    display: flex; gap: 10px; align-items: flex-end;
    border-top: 1px solid var(--border);
    padding-top: 16px;
  }

  .chat-input {
    flex: 1; padding: 12px 16px;
    border: 1px solid var(--border-strong);
    border-radius: 4px;
    font-family: var(--sans); font-size: 14px;
    background: #fff; color: var(--ink);
    resize: none; outline: none; min-height: 48px; max-height: 120px;
    transition: border-color 0.15s;
    line-height: 1.5;
  }

  .chat-input:focus { border-color: var(--gold); }
  .chat-input::placeholder { color: var(--muted); }

  .send-btn {
    padding: 12px 20px;
    background: var(--ink); color: var(--gold-light);
    border: none; border-radius: 4px; cursor: pointer;
    font-family: var(--mono); font-size: 12px;
    letter-spacing: 0.05em;
    transition: background 0.15s;
    white-space: nowrap; height: 48px;
  }

  .send-btn:hover { background: #2d2d2a; }
  .send-btn:disabled { opacity: 0.5; cursor: not-allowed; }

  .quick-chips { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 12px; }
  .chip {
    padding: 5px 12px; border: 1px solid var(--border-strong);
    border-radius: 20px; font-size: 12px; color: var(--muted);
    cursor: pointer; background: #fff; font-family: var(--sans);
    transition: all 0.15s;
  }
  .chip:hover { border-color: var(--gold); color: var(--gold); background: var(--gold-pale); }

  /* WATCHLIST FORM */
  .form-row { display: flex; gap: 10px; margin-bottom: 14px; flex-wrap: wrap; }
  .form-field { display: flex; flex-direction: column; gap: 4px; }
  .form-label { font-family: var(--mono); font-size: 10px; color: var(--muted); letter-spacing: 0.06em; text-transform: uppercase; }
  .form-input {
    padding: 8px 12px; border: 1px solid var(--border-strong);
    border-radius: 3px; font-family: var(--mono); font-size: 13px;
    background: #fff; color: var(--ink); outline: none;
    transition: border-color 0.15s; width: 120px;
  }
  .form-input:focus { border-color: var(--gold); }
  .form-input.wide { width: 200px; }

  .btn {
    padding: 8px 18px; border-radius: 3px; cursor: pointer;
    font-family: var(--mono); font-size: 12px; letter-spacing: 0.04em;
    border: 1px solid; transition: all 0.15s; align-self: flex-end;
  }
  .btn-primary { background: var(--ink); color: var(--gold-light); border-color: var(--ink); }
  .btn-primary:hover { background: #2d2d2a; }
  .btn-ghost { background: transparent; color: var(--ink); border-color: var(--border-strong); }
  .btn-ghost:hover { background: var(--paper2); }

  /* LOADING DOTS */
  .loading-dots span {
    display: inline-block; width: 5px; height: 5px; border-radius: 50%;
    background: var(--muted); margin: 0 2px;
    animation: bounce 1.2s infinite ease-in-out;
  }
  .loading-dots span:nth-child(2) { animation-delay: 0.15s; }
  .loading-dots span:nth-child(3) { animation-delay: 0.3s; }
  @keyframes bounce { 0%,80%,100%{transform:scale(0.6);opacity:0.4} 40%{transform:scale(1);opacity:1} }

  /* RULE ITEMS */
  .rule-item {
    display: flex; gap: 12px; padding: 10px 0;
    border-bottom: 1px solid rgba(26,26,24,0.06); align-items: flex-start;
  }
  .rule-item:last-child { border-bottom: none; }
  .rule-num {
    font-family: var(--serif); font-size: 18px; color: var(--gold);
    min-width: 24px; font-weight: 700; line-height: 1;
  }
  .rule-text { font-size: 13px; line-height: 1.6; color: var(--ink); }
  .rule-attr { font-family: var(--mono); font-size: 10px; color: var(--muted); margin-top: 2px; }

  /* SCROLL FINE-TUNING */
  .chat-messages::-webkit-scrollbar { width: 4px; }
  .chat-messages::-webkit-scrollbar-track { background: transparent; }
  .chat-messages::-webkit-scrollbar-thumb { background: var(--border-strong); border-radius: 2px; }

  /* DIVIDER */
  .divider { border: none; border-top: 1px solid var(--border); margin: 20px 0; }

  /* MARKET MOOD */
  .mood-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  .mood-card { padding: 14px 16px; border-radius: 3px; border: 1px solid; }
  .mood-title { font-family: var(--mono); font-size: 10px; letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 6px; }
  .mood-value { font-family: var(--serif); font-size: 20px; font-weight: 500; }
  .mood-desc { font-size: 11px; margin-top: 4px; }

  .typing-indicator { display: flex; align-items: center; gap: 8px; padding: 8px 0; }
</style>
</head>
